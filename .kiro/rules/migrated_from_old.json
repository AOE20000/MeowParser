      "collapsed": false,
      "rules": [
        {
          "enabled": true,
          "pattern": "([^喵])([。，！？；、）（：])",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "([^喵])([。，！？；、）（：]) → \\1喵\\2"
        },
        {
          "enabled": true,
          "pattern": "([^喵。，！？；、）（：\\n])(\\n)",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "([^喵。，！？；、）（：\\n])(\\n) → \\1喵\\2"
        },
        {
          "enabled": true,
          "pattern": "([^。，！？；、）（：\\n])$",
          "replacement": "\\1喵",
          "is_regex": true,
          "description": "([^。，！？；、）（：\\n])$ → \\1喵"
        },
        {
          "enabled": true,
          "pattern": "我",
          "replacement": "喵",
          "is_regex": false,
          "description": "我 → 喵"
        }
      ]
