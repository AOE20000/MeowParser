{
  "name": "喵语转换（默认）",
  "version": "1.0.0",
  "description": "将文本转换为可爱的喵语",
  "author": "MeowParser",
  "created": "2026-03-30 09:20:34",
  "updated": "2026-03-30 15:33:10",
  "groups": [
    {
      "name": "喵语转换",
      "description": "在标点前添加喵",
      "collapsed": false,
      "rules": [
        {
          "enabled": true,
          "pattern": "([^喵\\s。，！？；、）（：])([。！？])",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "句号、感叹号、问号前添加喵"
        },
        {
          "enabled": true,
          "pattern": "([^喵\\s。，！？；、）（：])([，、；])",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "逗号、顿号、分号前添加喵"
        },
        {
          "enabled": true,
          "pattern": "([^喵\\s。，！？；、）（：])([：])(?![a-zA-Z0-9_\\-\\.:/])",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "冒号前添加喵（排除URL和配置项）"
        },
        {
          "enabled": true,
          "pattern": "([^喵\\s。，！？；、）（：])(）)",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "右括号前添加喵"
        },
        {
          "enabled": true,
          "pattern": "(（)([^喵\\s])",
          "replacement": "\\1\\2",
          "is_regex": true,
          "description": "左括号后不添加喵（占位规则）"
        },
        {
          "enabled": true,
          "pattern": "([^喵。，！？；、）（：\\n])(\\n)",
          "replacement": "\\1喵\\2",
          "is_regex": true,
          "description": "换行前添加喵"
        },
        {
          "enabled": true,
          "pattern": "([^喵。，！？；、）（：\\n\\s.])$",
          "replacement": "\\1喵",
          "is_regex": true,
          "description": "句尾添加喵（排除英文句号结尾）"
        },
        {
          "enabled": true,
          "pattern": "我",
          "replacement": "喵",
          "is_regex": false,
          "description": "自称为喵"
        }
      ]
    }
  ]
}