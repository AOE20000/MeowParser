{
  "groups": {
    "喵语转换": {
      "enabled": true,
      "rules": [
        {
          "pattern": "([^喵])([。，！？；、）（：])",
          "replacement": "\\1喵\\2",
          "is_regex": true
        },
        {
          "pattern": "([^喵。，！？；、）（：\\n])(\\n)",
          "replacement": "\\1喵\\2",
          "is_regex": true
        },
        {
          "pattern": "([^。，！？；、）（：\\n])$",
          "replacement": "\\1喵",
          "is_regex": true
        },
        {
          "pattern": "我",
          "replacement": "喵",
          "is_regex": false
        }
      ]
    }
  }
}